{
    "name": "默认文书标注模板",
    "description": "用于文书数据标注的默认模板",
    "required_fields": [
        "s1", "s2", "s3", "s5", "s6", "s7", "s8", "s9", "s31", "s41", "s43",
        "s22", "s23", "s26", "s27", "s28", "s17", "s45", "s11", "wenshuAy",
        "relWenshu", "directory", "globalNet", "viewCount"
    ],
    "annotation_fields": [
        {
            "key": "review_result",
            "label": "审查结果",
            "type": "text",
            "required": true
        },
        {
            "key": "confidence",
            "label": "置信度",
            "type": "select",
            "options": [
                {"label": "高", "value": "high"},
                {"label": "中", "value": "medium"},
                {"label": "低", "value": "low"}
            ],
            "required": true
        },
        {
            "key": "review_type",
            "label": "审查类型",
            "type": "radio",
            "options": [
                {"label": "形式审查", "value": "formal"},
                {"label": "实质审查", "value": "substantive"}
            ],
            "required": true
        },
        {
            "key": "comments",
            "label": "备注",
            "type": "text",
            "required": false
        }
    ]
} 